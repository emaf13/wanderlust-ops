# Configuración de Nginx Proxy
# ============================

# Dominios para desarrollo local (nip.io resuelve automáticamente a localhost)
FRONTEND_DOMAIN=front.localhost.nip.io
BACKEND_DOMAIN=api.localhost.nip.io

# Dominios para producción (descomentar y configurar cuando despliegues)
# FRONTEND_DOMAIN=wanderlust.tudominio.com
# BACKEND_DOMAIN=api.wanderlust.tudominio.com

# SSL/HTTPS (opcional)
# LETSENCRYPT_HOST=wanderlust.tudominio.com,api.wanderlust.tudominio.com
# LETSENCRYPT_EMAIL=tu@email.com
